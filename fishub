<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FixHub PH — Trusted Tech & Appliance Repair</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
:root {
  --or: #FF5A00; --or2: #FF7A30; --or-dim: rgba(255,90,0,0.13); --or-glow: rgba(255,90,0,0.25);
  --bk: #0d0d0d; --bk2: #141414; --bk3: #1c1c1c; --bk4: #242424; --bk5: #2c2c2c;
  --wh: #ffffff; --wh2: rgba(255,255,255,0.85); --wh3: rgba(255,255,255,0.5);
  --wh4: rgba(255,255,255,0.18); --br: rgba(255,255,255,0.08);
  --br-or: rgba(255,90,0,0.3); --green: #22c55e; --amber: #f59e0b;
  --sidebar-w: 260px; --topbar-h: 64px;
  --radius: 14px; --radius-sm: 10px; --radius-lg: 20px;
  --shadow: 0 4px 24px rgba(0,0,0,0.4);
  --transition: .2s cubic-bezier(.4,0,.2,1);
}
html, body { height:100%; background:var(--bk); color:var(--wh); font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.5; overflow:hidden; }

/* ─── LAYOUT ─── */
.app { display:grid; grid-template-columns:var(--sidebar-w) 1fr; grid-template-rows:var(--topbar-h) 1fr; height:100vh; }

/* ─── TOP BAR ─── */
.topbar {
  grid-column:1/-1; display:flex; align-items:center; gap:16px;
  background:var(--bk2); border-bottom:1px solid var(--br);
  padding:0 24px; z-index:100; position:relative;
}
.logo { display:flex; align-items:center; gap:10px; width:var(--sidebar-w); padding-right:24px; flex-shrink:0; }
.logo-icon { font-size:22px; }
.logo-text { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; letter-spacing:-.5px; }
.logo-text span { color:var(--or); }
.topbar-search {
  flex:1; display:flex; align-items:center; gap:10px;
  background:var(--bk3); border:1px solid var(--br); border-radius:10px;
  padding:10px 16px; max-width:480px; cursor:text; transition:var(--transition);
}
.topbar-search:focus-within { border-color:var(--br-or); background:var(--bk4); }
.topbar-search input { background:none; border:none; outline:none; color:var(--wh); font-size:14px; font-family:'DM Sans',sans-serif; flex:1; }
.topbar-search input::placeholder { color:var(--wh3); }
.topbar-actions { display:flex; align-items:center; gap:10px; margin-left:auto; }
.icon-btn {
  width:38px; height:38px; border-radius:10px; background:var(--bk3); border:1px solid var(--br);
  display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:16px;
  transition:var(--transition); position:relative;
}
.icon-btn:hover { background:var(--bk4); border-color:var(--br-or); }
.notif-badge {
  position:absolute; top:-5px; right:-5px; width:18px; height:18px;
  background:var(--or); border-radius:50%; font-size:10px; font-weight:700;
  display:flex; align-items:center; justify-content:center; font-family:'Syne',sans-serif;
  border:2px solid var(--bk2);
}
.user-chip {
  display:flex; align-items:center; gap:8px; background:var(--bk3); border:1px solid var(--br);
  border-radius:10px; padding:6px 12px 6px 6px; cursor:pointer; transition:var(--transition);
}
.user-chip:hover { border-color:var(--br-or); }
.avatar { width:28px; height:28px; border-radius:50%; background:var(--or-dim); border:2px solid var(--br-or); display:flex; align-items:center; justify-content:center; font-family:'Syne',sans-serif; font-weight:800; font-size:10px; color:var(--or); flex-shrink:0; }
.avatar.md { width:40px; height:40px; font-size:13px; }
.avatar.lg { width:56px; height:56px; font-size:16px; }
.avatar.xl { width:72px; height:72px; font-size:20px; }
.user-name { font-size:13px; font-weight:600; }

/* ─── SIDEBAR ─── */
.sidebar {
  background:var(--bk2); border-right:1px solid var(--br);
  display:flex; flex-direction:column; overflow-y:auto; padding:20px 12px;
}
.sidebar::-webkit-scrollbar { width:4px; }
.sidebar::-webkit-scrollbar-track { background:transparent; }
.sidebar::-webkit-scrollbar-thumb { background:var(--bk5); border-radius:4px; }
.nav-section-label { font-size:10px; color:var(--wh3); font-weight:700; letter-spacing:1px; text-transform:uppercase; padding:0 12px; margin-bottom:6px; margin-top:20px; }
.nav-section-label:first-child { margin-top:0; }
.nav-link {
  display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:10px;
  cursor:pointer; transition:var(--transition); color:var(--wh3); font-weight:500; font-size:14px;
  position:relative; user-select:none;
}
.nav-link:hover { background:var(--bk3); color:var(--wh); }
.nav-link.active { background:var(--or-dim); color:var(--or2); }
.nav-link.active::before { content:''; position:absolute; left:0; top:6px; bottom:6px; width:3px; background:var(--or); border-radius:0 3px 3px 0; }
.nav-icon { font-size:18px; width:20px; text-align:center; flex-shrink:0; }
.nav-badge { margin-left:auto; background:var(--or); color:white; font-size:10px; font-weight:700; padding:2px 7px; border-radius:100px; font-family:'Syne',sans-serif; }
.sidebar-bottom { margin-top:auto; padding-top:20px; border-top:1px solid var(--br); }
.sidebar-tech-switch { background:linear-gradient(135deg, var(--or-dim), transparent); border:1px solid var(--br-or); border-radius:12px; padding:14px; text-align:center; cursor:pointer; }
.sidebar-tech-switch h4 { font-size:13px; font-weight:700; margin-bottom:4px; }
.sidebar-tech-switch p { font-size:11px; color:var(--wh3); margin-bottom:10px; }
.btn-or-sm { background:var(--or); color:white; border:none; padding:8px 16px; border-radius:8px; font-family:'Syne',sans-serif; font-size:12px; font-weight:700; cursor:pointer; width:100%; transition:var(--transition); }
.btn-or-sm:hover { background:var(--or2); }

/* ─── MAIN CONTENT ─── */
.main { overflow-y:auto; overflow-x:hidden; background:var(--bk); }
.main::-webkit-scrollbar { width:6px; }
.main::-webkit-scrollbar-track { background:transparent; }
.main::-webkit-scrollbar-thumb { background:var(--bk5); border-radius:4px; }

/* ─── VIEWS ─── */
.view { display:none; padding:28px 32px; animation:fadeUp .25s ease; min-height:calc(100vh - var(--topbar-h)); }
.view.active { display:block; }
@keyframes fadeUp { from{opacity:0; transform:translateY(12px)} to{opacity:1; transform:translateY(0)} }

/* ─── GENERAL COMPONENTS ─── */
.page-title { font-family:'Syne',sans-serif; font-size:26px; font-weight:800; margin-bottom:4px; }
.page-sub { font-size:14px; color:var(--wh3); margin-bottom:28px; }
.section-label { font-family:'Syne',sans-serif; font-size:16px; font-weight:700; margin-bottom:16px; }
.divider { height:1px; background:var(--br); margin:20px 0; }
.tag { display:inline-flex; align-items:center; gap:4px; background:var(--or-dim); border:1px solid var(--br-or); color:var(--or2); font-size:11px; font-weight:700; padding:3px 10px; border-radius:100px; letter-spacing:.3px; }
.tag.green { background:rgba(34,197,94,0.1); border-color:rgba(34,197,94,0.25); color:var(--green); }
.tag.amber { background:rgba(245,158,11,0.1); border-color:rgba(245,158,11,0.25); color:var(--amber); }
.stars { color:var(--or); font-size:13px; letter-spacing:1px; }
.dot-open { width:8px; height:8px; border-radius:50%; background:var(--green); display:inline-block; }
.dot-busy { width:8px; height:8px; border-radius:50%; background:var(--amber); display:inline-block; }
.badge-pill { display:inline-flex; align-items:center; gap:4px; background:var(--bk3); border:1px solid var(--br); border-radius:100px; padding:4px 10px; font-size:11px; color:var(--wh3); }
.score-pill { background:var(--or-dim); border:1px solid var(--br-or); color:var(--or2); font-size:11px; font-weight:700; padding:3px 10px; border-radius:100px; }
.card { background:var(--bk2); border:1px solid var(--br); border-radius:var(--radius); padding:20px; }
.card:hover { border-color:rgba(255,255,255,0.12); }
.card.interactive { cursor:pointer; transition:var(--transition); }
.card.interactive:hover { border-color:var(--br-or); transform:translateY(-1px); box-shadow:0 8px 24px rgba(0,0,0,.3); }
.btn-or { background:var(--or); color:white; border:none; padding:12px 24px; border-radius:10px; font-family:'Syne',sans-serif; font-size:14px; font-weight:700; cursor:pointer; transition:var(--transition); white-space:nowrap; }
.btn-or:hover { background:var(--or2); box-shadow:0 4px 16px var(--or-glow); }
.btn-ghost { background:transparent; color:var(--wh); border:1px solid var(--wh4); padding:12px 24px; border-radius:10px; font-family:'Syne',sans-serif; font-size:14px; font-weight:600; cursor:pointer; transition:var(--transition); white-space:nowrap; }
.btn-ghost:hover { background:var(--bk3); border-color:var(--wh4); }
.input-label { font-size:11px; color:var(--wh3); font-weight:700; letter-spacing:.5px; text-transform:uppercase; display:block; margin-bottom:6px; }
.inp { width:100%; background:var(--bk3); border:1px solid var(--br); border-radius:10px; padding:12px 14px; color:var(--wh); font-size:14px; font-family:'DM Sans',sans-serif; outline:none; transition:var(--transition); }
.inp:focus { border-color:var(--br-or); background:var(--bk4); }
.inp::placeholder { color:var(--wh3); }
.chip { display:inline-flex; align-items:center; padding:7px 14px; border-radius:100px; background:var(--bk3); border:1px solid var(--br); font-size:13px; color:var(--wh3); cursor:pointer; transition:var(--transition); white-space:nowrap; user-select:none; }
.chip:hover { border-color:var(--br-or); color:var(--wh); }
.chip.active { background:var(--or-dim); border-color:var(--br-or); color:var(--or2); font-weight:600; }
.chip-row { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:20px; }

/* ─── GRID HELPERS ─── */
.grid-2 { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
.grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
.grid-4 { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }

/* ─── TECH CARD (LIST STYLE) ─── */
.tech-row {
  display:flex; align-items:center; gap:16px; padding:18px 20px;
  background:var(--bk2); border:1px solid var(--br); border-radius:var(--radius);
  margin-bottom:10px; cursor:pointer; transition:var(--transition);
}
.tech-row:hover { border-color:var(--br-or); transform:translateX(2px); }
.tech-info { flex:1; }
.tech-name { font-size:15px; font-weight:700; margin-bottom:3px; }
.tech-spec { font-size:13px; color:var(--wh3); margin-bottom:6px; }
.tech-meta { display:flex; align-items:center; gap:10px; }
.tech-rate { font-family:'Syne',sans-serif; font-size:16px; font-weight:800; color:var(--or); }
.tech-rate-lbl { font-size:11px; color:var(--wh3); }
.tech-actions { display:flex; gap:8px; align-items:center; margin-left:auto; }

/* ─── STAT BOX ─── */
.stat-box { background:var(--bk2); border:1px solid var(--br); border-radius:var(--radius); padding:20px 22px; }
.stat-num { font-family:'Syne',sans-serif; font-size:28px; font-weight:800; color:var(--or); line-height:1; }
.stat-lbl { font-size:12px; color:var(--wh3); margin-top:6px; }
.stat-delta { font-size:12px; color:var(--green); font-weight:600; margin-top:4px; }

/* ─── HOME VIEW ─── */
.hero-banner {
  background:linear-gradient(135deg, #180800 0%, var(--bk3) 100%);
  border:1px solid var(--br-or); border-radius:var(--radius-lg);
  padding:32px 36px; margin-bottom:28px; display:flex; align-items:center; justify-content:space-between;
  position:relative; overflow:hidden;
}
.hero-banner::before { content:''; position:absolute; top:-60px; right:-60px; width:200px; height:200px; background:radial-gradient(circle, var(--or-glow) 0%, transparent 70%); border-radius:50%; }
.hero-banner::after { content:''; position:absolute; bottom:-40px; left:200px; width:140px; height:140px; background:radial-gradient(circle, rgba(255,90,0,0.08) 0%, transparent 70%); border-radius:50%; }
.hero-badge { font-size:11px; font-weight:700; color:var(--or2); background:var(--or-dim); border:1px solid var(--br-or); padding:4px 12px; border-radius:100px; display:inline-block; margin-bottom:12px; letter-spacing:.5px; }
.hero-title { font-family:'Syne',sans-serif; font-size:28px; font-weight:800; line-height:1.2; margin-bottom:8px; }
.hero-sub { font-size:14px; color:var(--wh3); margin-bottom:20px; }
.hero-emoji { font-size:72px; position:relative; z-index:1; }
.cat-grid { display:grid; grid-template-columns:repeat(8,1fr); gap:10px; margin-bottom:28px; }
.cat-item { background:var(--bk2); border:1px solid var(--br); border-radius:var(--radius); padding:16px 8px; text-align:center; cursor:pointer; transition:var(--transition); }
.cat-item:hover { border-color:var(--br-or); background:var(--or-dim); transform:translateY(-2px); }
.cat-icon { font-size:28px; margin-bottom:8px; }
.cat-name { font-size:11px; color:var(--wh3); font-weight:600; }
.promo-strip { display:flex; align-items:center; gap:16px; background:var(--bk3); border:1px solid var(--br); border-radius:var(--radius); padding:14px 20px; margin-bottom:24px; }
.promo-strip p { font-size:13px; color:var(--wh3); flex:1; }
.promo-code { font-family:'Syne',sans-serif; font-weight:700; color:var(--or); }

/* ─── CATEGORY SECTION GRID ─── */
.section-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
.see-all { font-size:13px; color:var(--or); cursor:pointer; font-weight:600; }
.see-all:hover { text-decoration:underline; }

/* ─── TECHNICIAN PROFILE VIEW ─── */
.profile-layout { display:grid; grid-template-columns:320px 1fr; gap:24px; align-items:start; }
.profile-sidebar { position:sticky; top:0; }
.profile-card { background:var(--bk2); border:1px solid var(--br); border-radius:var(--radius-lg); padding:28px; text-align:center; }
.profile-name { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; margin-top:14px; margin-bottom:4px; }
.profile-spec { font-size:14px; color:var(--wh3); margin-bottom:12px; }
.profile-rating { display:flex; align-items:center; justify-content:center; gap:8px; margin-bottom:16px; }
.profile-badges { display:flex; flex-wrap:wrap; gap:6px; justify-content:center; margin-bottom:20px; }
.profile-stat-row { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:20px; }
.p-stat { background:var(--bk3); border-radius:10px; padding:14px 10px; text-align:center; }
.p-stat-num { font-family:'Syne',sans-serif; font-size:20px; font-weight:800; color:var(--or); }
.p-stat-lbl { font-size:10px; color:var(--wh3); margin-top:4px; }
.score-ring { width:52px; height:52px; border-radius:50%; background:var(--or-dim); border:3px solid var(--or); display:flex; align-items:center; justify-content:center; flex-direction:column; margin:0 auto; }
.score-num { font-family:'Syne',sans-serif; font-size:14px; font-weight:800; color:var(--or); }
.score-lbl { font-size:7px; color:var(--or2); }
.profile-actions { display:grid; grid-template-columns:1fr 1fr; gap:10px; }

/* services pricing table */
.service-row { display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--br); }
.service-row:last-child { border-bottom:none; }
.service-price { font-weight:700; color:var(--or); font-family:'Syne',sans-serif; }

/* review card */
.review-card { background:var(--bk3); border:1px solid var(--br); border-radius:var(--radius-sm); padding:16px; margin-bottom:10px; }
.review-header { display:flex; align-items:center; gap:10px; margin-bottom:10px; }
.reviewer-name { font-size:13px; font-weight:700; }
.review-date { font-size:11px; color:var(--wh3); margin-left:auto; }
.review-text { font-size:13px; color:var(--wh3); line-height:1.6; }

/* portfolio grid */
.portfolio-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:20px; }
.portfolio-item { background:var(--bk3); border-radius:10px; aspect-ratio:1; display:flex; align-items:center; justify-content:center; font-size:32px; cursor:pointer; border:1px solid var(--br); transition:var(--transition); }
.portfolio-item:hover { border-color:var(--br-or); transform:scale(1.02); }

/* ─── BOOKING VIEW ─── */
.booking-layout { display:grid; grid-template-columns:1fr 360px; gap:24px; align-items:start; }
.booking-summary { position:sticky; top:0; background:var(--bk2); border:1px solid var(--br); border-radius:var(--radius-lg); padding:24px; }
.summary-line { display:flex; justify-content:space-between; margin-bottom:10px; font-size:14px; }
.summary-line .lbl { color:var(--wh3); }
.summary-total { font-family:'Syne',sans-serif; font-size:22px; font-weight:800; color:var(--or); }
.svc-type-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:24px; }
.svc-type { background:var(--bk3); border:2px solid var(--br); border-radius:var(--radius); padding:20px; text-align:center; cursor:pointer; transition:var(--transition); }
.svc-type:hover { border-color:var(--br-or); }
.svc-type.selected { border-color:var(--or); background:var(--or-dim); }
.svc-icon { font-size:32px; margin-bottom:10px; }
.svc-title { font-size:14px; font-weight:700; margin-bottom:4px; }
.svc-desc { font-size:12px; color:var(--wh3); }
.time-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:24px; }
.time-slot { background:var(--bk3); border:1px solid var(--br); border-radius:8px; padding:11px; text-align:center; cursor:pointer; font-size:13px; font-weight:600; transition:var(--transition); }
.time-slot:hover { border-color:var(--br-or); }
.time-slot.selected { border-color:var(--or); background:var(--or-dim); color:var(--or); }
.date-chips { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:24px; }

/* ─── PAYMENT VIEW ─── */
.payment-layout { display:grid; grid-template-columns:1fr 380px; gap:24px; align-items:start; }
.pay-method { display:flex; align-items:center; gap:16px; background:var(--bk3); border:2px solid var(--br); border-radius:var(--radius); padding:18px 20px; cursor:pointer; margin-bottom:10px; transition:var(--transition); }
.pay-method:hover { border-color:var(--br-or); }
.pay-method.selected { border-color:var(--or); background:var(--or-dim); }
.pay-logo { width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:22px; background:var(--bk4); flex-shrink:0; }
.pay-method h4 { font-size:15px; font-weight:700; margin-bottom:2px; }
.pay-method p { font-size:12px; color:var(--wh3); }
.pay-radio { width:20px; height:20px; border-radius:50%; border:2px solid var(--br); margin-left:auto; flex-shrink:0; display:flex; align-items:center; justify-content:center; }
.pay-method.selected .pay-radio { border-color:var(--or); background:var(--or); }
.pay-method.selected .pay-radio::after { content:''; width:8px; height:8px; background:#fff; border-radius:50%; }
.promo-row { display:flex; gap:8px; }
.promo-row .inp { flex:1; }
.apply-btn { background:var(--or); border:none; border-radius:10px; padding:0 20px; color:white; font-weight:700; cursor:pointer; font-family:'Syne',sans-serif; font-size:14px; white-space:nowrap; transition:var(--transition); }
.apply-btn:hover { background:var(--or2); }

/* ─── CONFIRM VIEW ─── */
.confirm-layout { display:grid; grid-template-columns:1fr 360px; gap:24px; align-items:start; }
.confirm-check { width:64px; height:64px; background:var(--or); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:28px; margin-bottom:16px; }
.tracker { display:flex; flex-direction:column; }
.tracker-step { display:flex; gap:16px; align-items:flex-start; }
.tracker-dot-col { display:flex; flex-direction:column; align-items:center; }
.tracker-dot { width:16px; height:16px; border-radius:50%; border:2px solid var(--br); flex-shrink:0; margin-top:2px; }
.tracker-dot.done { background:var(--or); border-color:var(--or); }
.tracker-dot.active { border-color:var(--or); background:var(--or-dim); animation:pulse2 1.5s infinite; }
@keyframes pulse2 { 0%,100%{box-shadow:0 0 0 0 rgba(255,90,0,.5)} 50%{box-shadow:0 0 0 6px rgba(255,90,0,0)} }
.tracker-line { width:2px; flex:1; min-height:32px; background:var(--br); }
.tracker-line.done { background:var(--or); }
.tracker-info { padding-bottom:24px; }
.tracker-title { font-size:14px; font-weight:700; margin-bottom:3px; }
.tracker-sub { font-size:12px; color:var(--wh3); }

/* ─── BOOKINGS LIST VIEW ─── */
.booking-card { background:var(--bk2); border:1px solid var(--br); border-radius:var(--radius); padding:20px; margin-bottom:12px; cursor:pointer; transition:var(--transition); }
.booking-card:hover { border-color:var(--br-or); }
.booking-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.booking-tech-row { display:flex; align-items:center; gap:12px; margin-bottom:12px; }
.booking-footer { display:flex; align-items:center; justify-content:space-between; }
.booking-amount { font-family:'Syne',sans-serif; font-size:18px; font-weight:800; color:var(--or); }

