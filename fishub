<script>
// ─── NAVIGATION ───
const views = ['login','signup','home','search','tech-profile','booking','payment','confirm','review','bookings','messages','profile','notifs','tech-dash'];
const navLinks = ['home','search','bookings','messages','profile','notifs'];

function nav(id) {
  views.forEach(v => {
    const el = document.getElementById('v-' + v);
    if(el) el.classList.remove('active');
  });
  const target = document.getElementById('v-' + id);
  if(target) { target.classList.add('active'); target.scrollTop = 0; }

  // Sidebar active state
  navLinks.forEach(l => {
    const nl = document.getElementById('nl-' + l);
    if(nl) nl.classList.remove('active');
  });
  const active = document.getElementById('nl-' + id);
  if(active) active.classList.add('active');

  // Show/hide sidebar + topbar for auth screens
  const isAuth = (id === 'login' || id === 'signup');
  document.querySelector('.sidebar').style.display = isAuth ? 'none' : '';
  document.querySelector('.topbar').style.display = isAuth ? 'none' : '';
  if(isAuth) {
    document.getElementById('app').style.gridTemplateColumns = '1fr';
    document.getElementById('app').style.gridTemplateRows = '1fr';
  } else {
    document.getElementById('app').style.gridTemplateColumns = 'var(--sidebar-w) 1fr';
    document.getElementById('app').style.gridTemplateRows = 'var(--topbar-h) 1fr';
  }
}

// ─── ACCOUNT TYPE ───
function selectAccType(type) {
  document.getElementById('at-customer').classList.toggle('selected', type==='customer');
  document.getElementById('at-tech').classList.toggle('selected', type==='tech');
}

// ─── SERVICE TYPE ───
function selectSvc(type) {
  document.getElementById('svc-home').classList.toggle('selected', type==='home');
  document.getElementById('svc-drop').classList.toggle('selected', type==='drop');
}

// ─── PAYMENT ───
function selectPay(type) {
  document.getElementById('pay-gcash').classList.toggle('selected', type==='gcash');
  document.getElementById('pay-maya').classList.toggle('selected', type==='maya');
}

// ─── CHIP SELECT ───
function setChip(el) {
  const row = el.closest('.chip-row');
  if(row) row.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}

// ─── TIME SLOT ───
function setTimeSlot(el) {
  document.querySelectorAll('#v-booking .time-slot').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
}

// ─── STARS ───
let starCount = 4;
function setStars(n) {
  starCount = n;
  const stars = document.querySelectorAll('.star-btn');
  const labels = ['','Terrible','Poor','Good','Very Good','Excellent!'];
  stars.forEach((s,i) => s.classList.toggle('lit', i < n));
  document.getElementById('star-label').textContent = labels[n];
}

// ─── TOAST ───
let toastTimer;
function showToast(msg) {
  const el = document.getElementById('toast');
  const match = msg.match(/^([\s\S]{1,4}?)\s(.+)$/);
  document.getElementById('toast-icon').textContent = match ? match[1] : '✨';
  document.getElementById('toast-text').textContent = match ? match[2] : msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);
}

// Start on login
nav('login');
</script>
